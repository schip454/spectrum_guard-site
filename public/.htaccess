# Spectrum Guard — Apache конфигурация для шаред-хостинга (reg.ru).
# Каноникал: https + единый trailing slash. Кэш, сжатие, 404.

Options -Indexes
DirectoryIndex index.html

# ---------- Защита секретов ----------
<FilesMatch "lead\.config(\.sample)?\.php$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS (канонический протокол). Раскомментировать, если хостинг не редиректит сам.
  # RewriteCond %{HTTPS} off
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # www → без www (один канонический хост).
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Не трогаем реальные файлы и каталоги, а также API.
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Убираем index.html из адреса.
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
  RewriteRule ^(.*/)?index\.html$ /%1 [R=301,L]

  # Единый trailing slash: добавляем «/» к путям без расширения.
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{1,8})$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ /$1/ [R=301,L]
</IfModule>

# ---------- 404 ----------
ErrorDocument 404 /404.html

# ---------- Сжатие ----------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain application/xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml
</IfModule>

# ---------- Кэш-заголовки ----------
<IfModule mod_expires.c>
  ExpiresActive On
  # Хэшированные ассеты Astro (_astro/...) — год, immutable.
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
  # HTML — короткий кэш (контент обновляется).
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|avif|webp|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # Безопасность (мягкий набор, не ломает статику).
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

AddDefaultCharset UTF-8
AddType image/svg+xml .svg
AddType font/woff2 .woff2
