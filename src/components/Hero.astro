---
/**
 * Главный герой: реальный тёмный кадр под затемнением, слоган капсом display-шрифтом,
 * сигнатурная рамка-периметр. Одно главное действие (заявка) + один второстепенный
 * способ связи (Telegram). Без координат и без конкурирующих CTA.
 * Интент-карточки услуг вынесены в отдельную секцию ниже (ServicesShowcase).
 */
import Media from './Media.astro';
import Icon from './icons/Icon.astro';
import { contacts } from '../data/contacts';
import { SHOW_PHONE } from '../config';

const heroImage = 'hero/msk-kotelnicheskaya-sunset-hero.webp';
---

<section class="hero">
  <div class="hero__bg">
    <Media
      src={heroImage}
      alt="Spectrum Guard — личная безопасность и сопровождение"
      sizes="100vw"
      widths={[768, 1080, 1280]}
      loading="eager"
      fetchpriority="high"
      class="hero__img"
    />
    <div class="hero__scrim" aria-hidden="true"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__frame perimeter perimeter--full">
      <span class="perimeter__corner tl"></span>
      <span class="perimeter__corner tr"></span>
      <span class="perimeter__corner bl"></span>
      <span class="perimeter__corner br"></span>

      <p class="hero__eyebrow mono">Охранное агентство · работаем по всей России</p>
      <h1 class="hero__title display">Мы заботимся<br />о вашей безопасности</h1>
      <p class="hero__lead">
        Профессиональная защита для частных лиц и бизнеса: личная охрана, охрана мероприятий
        и сопровождение ценных грузов. Подбираем формат под задачу — от разовой смены до
        постоянной защиты.
      </p>

      <div class="hero__actions">
        <a href="#lead" class="hero__cta hero__cta--primary">
          Оставить заявку <Icon name="arrow" size={18} />
        </a>
        <a
          href={contacts.telegram.url}
          class="hero__cta hero__cta--ghost"
          rel="noopener"
          target="_blank"
        >
          <Icon name="telegram" size={18} /> Написать в Telegram
        </a>
      </div>

      <p class="hero__note">
        <Icon name="pin" size={16} /> Собственная команда в ключевых городах, выезд в любой регион России.
      </p>
    </div>

    {
      SHOW_PHONE && (
        <aside class="hero__aside">
          <p class="hero__aside-label mono">Звонок за консультацией</p>
          <div class="hero__aside-phones">
            {contacts.phones.map((p) => (
              <a href={`tel:${p.tel}`} class="hero__phone">
                <span class="hero__phone-icon"><Icon name="phone" size={18} /></span>
                <span class="hero__phone-num">{p.display}</span>
              </a>
            ))}
          </div>
          <p class="hero__aside-hint mono">Ответим и подскажем формат</p>
        </aside>
      )
    }
  </div>
</section>

<script>
  // Тонкий параллакс фонового кадра героя. Отключаем при reduced-motion и на тач/узких.
  const bg = document.querySelector<HTMLElement>('.hero__bg');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (bg && !reduceMotion && window.matchMedia('(min-width: 720px)').matches) {
    let ticking = false;
    const update = () => {
      const y = Math.min(window.scrollY * 0.12, 90);
      bg.style.transform = `translate3d(0, ${y}px, 0)`;
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
    update();
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: clamp(520px, 78vh, 760px);
    display: flex;
    align-items: center;
    padding-block: var(--space-16) var(--space-12);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    left: 0;
    right: 0;
    top: -12%;
    height: 124%;
    z-index: 0;
    will-change: transform;
  }
  .hero__bg :global(.hero__img),
  .hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(11, 13, 16, 0.55) 0%, rgba(11, 13, 16, 0.78) 70%, var(--bg-900) 100%),
      radial-gradient(120% 90% at 15% 20%, rgba(11, 13, 16, 0.2), transparent 60%);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vw, 3.5rem);
  }

  .hero__frame {
    max-width: 46rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    outline-color: var(--line-2);
    background: color-mix(in srgb, var(--bg-900) 35%, transparent);
    backdrop-filter: blur(2px);
  }
  .hero__frame > .perimeter__corner {
    opacity: 0;
    animation: corner-in 0.5s var(--ease) forwards;
  }
  .hero__frame .tl { animation-delay: 0.05s; }
  .hero__frame .tr { animation-delay: 0.15s; }
  .hero__frame .bl { animation-delay: 0.25s; }
  .hero__frame .br { animation-delay: 0.35s; }
  @keyframes corner-in {
    from { opacity: 0; transform: scale(0.6); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Появление контента героя на загрузке (тонко, со стаггером) */
  @keyframes hero-up {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }
  .hero__eyebrow,
  .hero__title,
  .hero__lead,
  .hero__actions,
  .hero__note {
    opacity: 0;
    animation: hero-up 0.6s var(--ease) forwards;
  }
  .hero__eyebrow { animation-delay: 0.1s; }
  .hero__title { animation-delay: 0.18s; }
  .hero__lead { animation-delay: 0.3s; }
  .hero__actions { animation-delay: 0.42s; }
  .hero__note { animation-delay: 0.52s; }

  .hero__eyebrow {
    color: var(--accent);
    margin-bottom: var(--space-4);
  }
  .hero__title {
    font-size: var(--fs-display);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--text-100);
    margin-bottom: var(--space-6);
  }
  .hero__lead {
    max-width: 50ch;
    color: var(--text-100);
    font-size: 1.125rem;
  }
  .hero__note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    color: var(--text-300);
    font-size: var(--fs-small);
  }
  .hero__note :global(svg) {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* Телефоны справа от фрейма (на широких экранах) */
  .hero__aside {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--bg-900) 55%, transparent);
    backdrop-filter: blur(3px);
  }
  .hero__aside-label {
    color: var(--accent);
  }
  .hero__aside-phones {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .hero__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-100);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: color var(--dur) var(--ease);
  }
  .hero__phone-icon {
    display: inline-flex;
    padding: var(--space-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    color: var(--accent);
  }
  .hero__phone:hover {
    color: var(--accent);
  }
  .hero__aside-hint {
    color: var(--text-500);
    text-transform: none;
    letter-spacing: 0.01em;
  }
  @media (max-width: 980px) {
    .hero__aside {
      display: none;
    }
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.95rem 1.6rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    font-weight: 500;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease), transform var(--dur-fast) var(--ease);
  }
  .hero__cta--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #1a1206;
    font-weight: 700;
  }
  .hero__cta--primary:hover {
    background: #d4ab63;
  }
  .hero__cta--primary:active {
    transform: translateY(1px);
  }
  .hero__cta--ghost {
    border-color: var(--line-2);
    color: var(--text-100);
    background: color-mix(in srgb, var(--bg-900) 50%, transparent);
  }
  .hero__cta--ghost:hover {
    border-color: var(--accent);
  }
</style>
