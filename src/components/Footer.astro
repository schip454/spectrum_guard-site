---
/**
 * Подвал: услуги, города (перелинковка + мини-карта географии), контакты,
 * слот трастового блока (за флагом).
 */
import Logo from './Logo.astro';
import Icon from './icons/Icon.astro';
import TrustBlock from './TrustBlock.astro';
import { servicesNav, citiesNav, footerLinks } from '../data/nav';
import { contacts, telHref } from '../data/contacts';
import { SITE_NAME } from '../config';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <Logo compact />
        <p class="site-footer__mission">
          Личная безопасность, сопровождение и охрана в правовом поле. Спокойно, конкретно,
          без лишнего шума.
        </p>
        <a href={telHref} class="site-footer__phone">
          <Icon name="phone" size={18} />
          {contacts.phone.display}
        </a>
        <a href={`mailto:${contacts.email}`} class="site-footer__contact">
          <Icon name="mail" size={18} />
          {contacts.email}
        </a>
        <a href={contacts.telegram.url} class="site-footer__contact" rel="noopener" target="_blank">
          <Icon name="telegram" size={18} />
          {contacts.telegram.label}
        </a>
      </div>

      <nav class="site-footer__col" aria-label="Услуги">
        <h2 class="site-footer__heading">Услуги</h2>
        <ul>
          {servicesNav.map((i) => (
            <li><a href={i.href}>{i.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label="География">
        <h2 class="site-footer__heading">География</h2>
        <ul class="site-footer__cities">
          {citiesNav.map((i) => (
            <li><a href={i.href}>{i.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label="Компания">
        <h2 class="site-footer__heading">Компания</h2>
        <ul>
          {footerLinks.map((i) => (
            <li><a href={i.href}>{i.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <TrustBlock />

    <div class="site-footer__bottom">
      <p class="mono">© {year} {SITE_NAME}</p>
      <p class="mono">Работаем в правовом поле · Заявки 24/7</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    background: var(--bg-800);
    padding-block: var(--space-16) var(--space-8);
    margin-top: var(--space-24);
  }
  .site-footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-12) var(--col-gap);
    padding-bottom: var(--space-12);
  }
  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 34ch;
  }
  .site-footer__mission {
    color: var(--text-300);
    font-size: var(--fs-small);
    margin-bottom: var(--space-2);
  }
  .site-footer__phone,
  .site-footer__contact {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-100);
    font-size: var(--fs-small);
  }
  .site-footer__phone {
    font-weight: 700;
  }
  .site-footer__phone:hover,
  .site-footer__contact:hover {
    color: var(--accent);
  }

  .site-footer__heading {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--text-500);
    font-weight: 400;
    margin-bottom: var(--space-4);
  }
  .site-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .site-footer__col a {
    color: var(--text-300);
    font-size: var(--fs-small);
  }
  .site-footer__col a:hover {
    color: var(--text-100);
  }
  .site-footer__cities {
    columns: 2;
    gap: var(--space-4);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-8);
    margin-top: var(--space-8);
    border-top: 1px solid var(--line);
  }

  @media (max-width: 860px) {
    .site-footer__top {
      grid-template-columns: 1fr 1fr;
    }
    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }
    .site-footer__cities {
      columns: 2;
    }
  }
</style>
