---
/**
 * Обратный звонок: телефон → «перезвоним». Тот же бэкенд приёма (e-mail + Telegram).
 * Компактная форма-остров с honeypot и меткой времени.
 */
import Button from './Button.astro';
import Icon from './icons/Icon.astro';

interface Props {
  source?: string;
}
const { source = '' } = Astro.props;
---

<form class="callback" action="/api/lead.php" method="post" data-lead-form>
  <input type="hidden" name="source" value={`Обратный звонок · ${source}`} />
  <input type="hidden" name="method" value="phone" />
  <div class="lead-form__hp" aria-hidden="true">
    <label>Компания<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
  </div>
  <input type="hidden" name="_ts" value="" data-ts />
  <input type="hidden" name="name" value="Заявка на звонок" />

  <div class="callback__inner">
    <Icon name="phone" size={20} class="callback__icon" />
    <label class="callback__field">
      <span class="visually-hidden">Ваш телефон</span>
      <input type="tel" name="contact" required inputmode="tel" autocomplete="tel" placeholder="Ваш телефон" />
    </label>
    <Button type="submit" variant="primary" size="md">Перезвоните мне</Button>
  </div>
</form>

<style>
  .callback {
    width: 100%;
  }
  .callback__inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    padding: var(--space-2);
    background: var(--bg-900);
  }
  .callback__icon {
    margin-left: var(--space-2);
    color: var(--text-500);
    flex-shrink: 0;
  }
  .callback__field {
    flex: 1;
  }
  .callback input[type='tel'] {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 0.6rem 0.25rem;
    color: var(--text-100);
    font-size: var(--fs-body);
  }
  .callback input[type='tel']:focus {
    outline: none;
  }
  .lead-form__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  @media (max-width: 480px) {
    .callback__inner {
      flex-wrap: wrap;
    }
    .callback__field {
      flex-basis: 100%;
    }
  }
</style>
