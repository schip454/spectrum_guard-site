---
/**
 * Блок конверсии: форма заявки + Telegram + обратный звонок (три механики, единый бэкенд).
 * Ставится в конце услуговых/гео-страниц. Сигнатурная рамка-периметр обрамляет блок.
 */
import LeadForm from './LeadForm.astro';
import TelegramCTA from './TelegramCTA.astro';
import CallbackCTA from './CallbackCTA.astro';
import Icon from './icons/Icon.astro';
import { contacts, telHref } from '../data/contacts';

interface Props {
  source?: string;
  heading?: string;
  lead?: string;
}
const {
  source = '',
  heading = 'Оставьте заявку',
  lead = 'Опишите ситуацию — перезвоним или напишем, подскажем формат и стоимость. Без обязательств.',
} = Astro.props;
---

<section class="cta section" id="lead" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta__grid perimeter perimeter--full">
      <span class="perimeter__corner tl"></span>
      <span class="perimeter__corner tr"></span>
      <span class="perimeter__corner bl"></span>
      <span class="perimeter__corner br"></span>

      <div class="cta__intro">
        <p class="eyebrow">Связаться</p>
        <h2 id="cta-heading">{heading}</h2>
        <p class="cta__lead">{lead}</p>

        <div class="cta__alt">
          <p class="mono cta__alt-title">Или сразу</p>
          <TelegramCTA variant="ghost" size="lg" full />
          <a href={telHref} class="cta__phone">
            <Icon name="phone" size={18} />
            <span>{contacts.phone.display}</span>
          </a>
          <div class="cta__callback">
            <p class="mono cta__alt-title">Заказать звонок</p>
            <CallbackCTA source={source} />
          </div>
        </div>
      </div>

      <div class="cta__form">
        <LeadForm source={source} />
      </div>
    </div>
  </div>
</section>

<style>
  .cta__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding: clamp(2rem, 5vw, 3.5rem);
    background: var(--bg-800);
    outline-color: var(--line-2);
  }
  .cta__lead {
    color: var(--text-300);
    margin-top: var(--space-4);
    max-width: 46ch;
  }
  .cta__alt {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-6);
    border-top: 1px solid var(--line);
  }
  .cta__alt-title {
    color: var(--text-500);
  }
  .cta__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-100);
    font-weight: 700;
    font-size: var(--fs-h3);
  }
  .cta__phone:hover {
    color: var(--accent);
  }
  .cta__callback {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .cta__form {
    align-self: start;
  }

  @media (max-width: 820px) {
    .cta__grid {
      grid-template-columns: 1fr;
    }
    .cta__form {
      order: -1;
    }
  }
</style>
