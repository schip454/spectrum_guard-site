---
/**
 * Блок конверсии. Один понятный сценарий: форма заявки. Прямые контакты (Telegram,
 * Позвонить) — отдельной, визуально отделённой строкой, не смешаны с формой
 * (см. правки → пункт 7). Сигнатурная рамка-периметр обрамляет блок.
 */
import LeadForm from './LeadForm.astro';
import Icon from './icons/Icon.astro';
import { contacts, telHref } from '../data/contacts';

interface Props {
  source?: string;
  heading?: string;
  lead?: string;
}
const {
  source = '',
  heading = 'Оставьте заявку',
  lead = 'Опишите ситуацию — перезвоним или напишем, подскажем формат и стоимость. Без обязательств.',
} = Astro.props;
---

<section class="cta section" id="lead" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta__grid perimeter perimeter--full">
      <span class="perimeter__corner tl"></span>
      <span class="perimeter__corner tr"></span>
      <span class="perimeter__corner bl"></span>
      <span class="perimeter__corner br"></span>

      <div class="cta__intro">
        <p class="eyebrow">Связаться</p>
        <h2 id="cta-heading">{heading}</h2>
        <p class="cta__lead">{lead}</p>

        <ul class="cta__points">
          <li><Icon name="check" size={18} /> Ответим и подберём формат под задачу</li>
          <li><Icon name="check" size={18} /> Работаем в правовом поле, конфиденциально</li>
          <li><Icon name="check" size={18} /> Заявки принимаем круглосуточно</li>
        </ul>
      </div>

      <div class="cta__form">
        <LeadForm source={source} id={`lead-form-${source ? 'page' : 'main'}`} />
      </div>
    </div>

    {/* Прямые контакты — отдельная строка, отделена от формы */}
    <div class="cta__direct">
      <span class="cta__direct-label mono">Удобнее иначе?</span>
      <a href={contacts.telegram.url} class="cta__direct-btn" rel="noopener" target="_blank">
        <Icon name="telegram" size={18} /> Написать в Telegram
      </a>
      <a href={telHref} class="cta__direct-btn">
        <Icon name="phone" size={18} /> Позвонить {contacts.phone.display}
      </a>
    </div>
  </div>
</section>

<style>
  .cta__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding: clamp(2rem, 5vw, 3.5rem);
    background: var(--bg-800);
    outline-color: var(--line-2);
  }
  .cta__lead {
    color: var(--text-300);
    margin-top: var(--space-4);
    max-width: 46ch;
  }
  .cta__points {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .cta__points li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-100);
    font-size: var(--fs-small);
  }
  .cta__points :global(svg) {
    color: var(--accent);
    flex-shrink: 0;
  }
  .cta__form {
    align-self: start;
  }

  /* Прямые контакты — отдельная отделённая строка */
  .cta__direct {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
    padding: var(--space-5, 1.25rem) var(--space-6);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-900);
  }
  .cta__direct-label {
    color: var(--text-500);
    margin-right: auto;
  }
  .cta__direct-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    color: var(--text-100);
    font-size: var(--fs-small);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .cta__direct-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 820px) {
    .cta__grid {
      grid-template-columns: 1fr;
    }
    .cta__form {
      order: -1;
    }
    .cta__direct-label {
      margin-right: 0;
      flex-basis: 100%;
    }
  }
</style>
