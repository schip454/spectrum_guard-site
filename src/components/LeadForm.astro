---
/**
 * Форма заявки. Способ связи — строго ОДИН из двух: телефон ИЛИ Telegram (переключатель).
 * Для телефона — маска +7 (XXX) XXX-XX-XX под российский стандарт. Для Telegram — @username.
 * Согласие на обработку ПД (152-ФЗ) — обязательный чекбокс со ссылкой на политику.
 * Отправка на public/api/lead.php → e-mail + Telegram-бот. Анти-спам: honeypot + метка времени.
 */
import Button from './Button.astro';
import { cities } from '../data/cities';

interface Props {
  source?: string;
  id?: string;
}
const { source = '', id = 'lead-form' } = Astro.props;
const cityListId = `cities-${id}`;
---

<form class="lead-form" id={id} action="/api/lead.php" method="post" data-lead-form>
  <input type="hidden" name="source" value={source} />
  <div class="lead-form__hp" aria-hidden="true">
    <label>Компания<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
  </div>
  <input type="hidden" name="_ts" value="" data-ts />

  <label class="field">
    <span class="field__label">Как к вам обращаться</span>
    <input type="text" name="name" required autocomplete="name" placeholder="Имя" />
  </label>

  <fieldset class="field lead-form__method">
    <legend class="field__label">Как с вами связаться</legend>
    <div class="seg" role="radiogroup" aria-label="Способ связи">
      <label class="seg__opt">
        <input type="radio" name="method" value="phone" checked data-method-phone />
        <span>Телефон</span>
      </label>
      <label class="seg__opt">
        <input type="radio" name="method" value="telegram" data-method-tg />
        <span>Telegram</span>
      </label>
    </div>
    <input
      type="tel"
      name="contact"
      required
      autocomplete="tel"
      placeholder="+7 (___) ___-__-__"
      data-contact
      aria-label="Телефон для связи"
    />
    <p class="lead-form__hint mono" data-contact-hint>Введите номер телефона</p>
  </fieldset>

  <label class="field">
    <span class="field__label">Город</span>
    <input
      type="text"
      name="city"
      list={cityListId}
      autocomplete="address-level2"
      placeholder="Ваш город"
      data-city
    />
    <datalist id={cityListId}>
      {cities.map((c) => <option value={c.nom} />)}
    </datalist>
  </label>

  <label class="field">
    <span class="field__label">Коротко о ситуации <span class="field__opt">— необязательно</span></span>
    <textarea name="message" rows={3} placeholder="Что нужно"></textarea>
  </label>

  <label class="consent">
    <input type="checkbox" name="consent" required />
    <span>
      Согласен с <a href="/politika-konfidencialnosti/" target="_blank" rel="noopener">политикой
      конфиденциальности</a> и обработкой персональных данных.
    </span>
  </label>

  <Button type="submit" variant="primary" size="lg" full>Оставить заявку</Button>
  <p class="lead-form__note mono">Перезвоним или напишем. Без обязательств.</p>
</form>

<div class="lead-toast" data-toast role="status" aria-live="polite" hidden></div>

<script>
  // Маска российского номера: +7 (XXX) XXX-XX-XX
  function formatPhone(raw: string): string {
    let d = raw.replace(/\D/g, '');
    if (d.startsWith('8')) d = '7' + d.slice(1);
    else if (d.startsWith('9')) d = '7' + d;
    if (!d.startsWith('7')) d = '7' + d;
    d = d.slice(0, 11);
    const a = d.slice(1, 4),
      b = d.slice(4, 7),
      c = d.slice(7, 9),
      e = d.slice(9, 11);
    let out = '+7';
    if (a) out += ' (' + a;
    if (a.length === 3) out += ')';
    if (b) out += ' ' + b;
    if (c) out += '-' + c;
    if (e) out += '-' + e;
    return out;
  }

  const CITY_KEY = 'sg-city-name';
  document.querySelectorAll<HTMLFormElement>('[data-lead-form]').forEach((form) => {
    const tsField = form.querySelector<HTMLInputElement>('[data-ts]');
    if (tsField) tsField.value = String(Date.now());

    // Город: подставляем запомненный (из визита на страницу города), сохраняем при изменении.
    const cityField = form.querySelector<HTMLInputElement>('[data-city]');
    if (cityField) {
      const saved = localStorage.getItem(CITY_KEY);
      if (saved && !cityField.value) cityField.value = saved;
      cityField.addEventListener('change', () => {
        if (cityField.value.trim()) localStorage.setItem(CITY_KEY, cityField.value.trim());
      });
    }

    const contact = form.querySelector<HTMLInputElement>('[data-contact]');
    const hint = form.querySelector<HTMLElement>('[data-contact-hint]');
    const phoneRadio = form.querySelector<HTMLInputElement>('[data-method-phone]');
    const tgRadio = form.querySelector<HTMLInputElement>('[data-method-tg]');

    let mode: 'phone' | 'telegram' = 'phone';

    const onPhoneInput = (e: Event) => {
      const el = e.target as HTMLInputElement;
      el.value = formatPhone(el.value);
    };

    function setMode(next: 'phone' | 'telegram') {
      if (!contact) return;
      mode = next;
      contact.value = '';
      if (next === 'phone') {
        contact.type = 'tel';
        contact.inputMode = 'tel';
        contact.placeholder = '+7 (___) ___-__-__';
        contact.setAttribute('aria-label', 'Телефон для связи');
        contact.pattern = '\\+7 \\(\\d{3}\\) \\d{3}-\\d{2}-\\d{2}';
        contact.addEventListener('input', onPhoneInput);
        if (hint) hint.textContent = 'Введите номер телефона';
      } else {
        contact.type = 'text';
        contact.inputMode = 'text';
        contact.placeholder = '@username или ссылка t.me';
        contact.setAttribute('aria-label', 'Telegram для связи');
        contact.removeAttribute('pattern');
        contact.removeEventListener('input', onPhoneInput);
        if (hint) hint.textContent = 'Укажите ваш ник или ссылку в Telegram';
      }
    }

    phoneRadio?.addEventListener('change', () => phoneRadio.checked && setMode('phone'));
    tgRadio?.addEventListener('change', () => tgRadio.checked && setMode('telegram'));
    setMode('phone');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Доп. проверка телефона: 11 цифр
      if (mode === 'phone' && contact && contact.value.replace(/\D/g, '').length !== 11) {
        contact.setCustomValidity('Введите полный номер телефона');
        contact.reportValidity();
        contact.setCustomValidity('');
        return;
      }
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const toast = document.querySelector<HTMLElement>('[data-toast]');
      if (btn) {
        btn.disabled = true;
        btn.dataset.label = btn.textContent ?? '';
        btn.textContent = 'Отправляем…';
      }
      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
        if (!res.ok) throw new Error('bad status');
        form.reset();
        setMode('phone');
        if (tsField) tsField.value = String(Date.now());
        showToast('Заявка отправлена. Скоро свяжемся.', true);
      } catch {
        showToast('Не удалось отправить. Позвоните или напишите в Telegram.', false);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.textContent = btn.dataset.label || 'Оставить заявку';
        }
      }

      function showToast(msg: string, ok: boolean) {
        if (!toast) return;
        toast.textContent = msg;
        toast.dataset.ok = String(ok);
        toast.hidden = false;
        toast.classList.add('is-visible');
        window.setTimeout(() => {
          toast.classList.remove('is-visible');
          window.setTimeout(() => (toast.hidden = true), 300);
        }, 5000);
      }
    });
  });
</script>

<style>
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5, 1.25rem);
  }
  .lead-form__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border: 0;
    padding: 0;
    margin: 0;
  }
  .field__label {
    font-size: var(--fs-small);
    color: var(--text-300);
  }
  .field__opt {
    color: var(--text-500);
  }
  input[type='text'],
  input[type='tel'],
  textarea {
    width: 100%;
    background: var(--bg-900);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    padding: 0.8rem 0.95rem;
    color: var(--text-100);
    font-size: var(--fs-body);
    transition: border-color var(--dur) var(--ease);
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--text-500);
  }
  input:focus,
  textarea:focus {
    border-color: var(--accent);
    outline: none;
  }
  textarea {
    resize: vertical;
    min-height: 3rem;
  }

  /* Сегментированный переключатель способа связи */
  .lead-form__method {
    gap: var(--space-3);
  }
  .seg {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    padding: 4px;
    background: var(--bg-900);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
  }
  .seg__opt {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.75rem;
    border-radius: calc(var(--radius) - 1px);
    cursor: pointer;
    font-size: var(--fs-small);
    color: var(--text-300);
    transition: background-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .seg__opt input {
    position: absolute;
    opacity: 0;
    inset: 0;
    cursor: pointer;
  }
  .seg__opt:has(input:checked) {
    background: var(--accent-tint);
    color: var(--text-100);
    box-shadow: inset 0 0 0 1px var(--accent);
  }
  .seg__opt:has(input:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .lead-form__hint {
    color: var(--text-500);
    text-transform: none;
    letter-spacing: 0.01em;
  }

  /* Согласие */
  .consent {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    font-size: var(--fs-small);
    color: var(--text-300);
  }
  .consent input {
    margin-top: 3px;
    width: 16px;
    height: 16px;
    accent-color: var(--accent);
    flex-shrink: 0;
  }
  .consent a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .lead-form__note {
    color: var(--text-500);
    text-transform: none;
    letter-spacing: 0.01em;
    text-align: center;
  }

  .lead-toast {
    position: fixed;
    left: 50%;
    bottom: var(--space-8);
    transform: translate(-50%, 1rem);
    z-index: var(--z-toast);
    max-width: min(92vw, 420px);
    padding: var(--space-4) var(--space-6);
    background: var(--bg-700);
    border: 1px solid var(--line-2);
    border-left: 3px solid var(--ok);
    border-radius: var(--radius);
    color: var(--text-100);
    font-size: var(--fs-small);
    opacity: 0;
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .lead-toast[data-ok='false'] {
    border-left-color: var(--danger);
  }
  .lead-toast.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }
</style>
