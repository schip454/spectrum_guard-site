---
/**
 * Локальный блок гео-страницы. Для городов с фактурой (hasLocalProof) — реальный
 * локальный контекст и галерея кадров (через astro:assets). Без фактуры — честный
 * локальный контекст и нейтральный кадр, без фейковых «местных» подписей.
 */
import Media from './Media.astro';
import type { City } from '../data/types';

interface Props {
  city: City;
  serviceNom: string;
}
const { city, serviceNom } = Astro.props;
// Галерея: для фактурных городов — их кадры; иначе один нейтральный (если задан).
const gallery = city.hasLocalProof ? city.media.slice(0, 3) : city.media.slice(0, 1);
const hasMedia = gallery.length > 0;
---

<section class="local">
  <div class="local__text">
    <p class="eyebrow">{city.nom} · {city.region}</p>
    <h2>{serviceNom} {city.prep}</h2>
    {city.localContext && <p class="local__context">{city.localContext}</p>}
  </div>

  {
    hasMedia && (
      <div class:list={['local__media', `local__media--${gallery.length}`]}>
        {gallery.map((key) => (
          <figure class="local__frame">
            <Media
              src={key}
              alt={`${serviceNom} ${city.prep} — Spectrum Guard`}
              sizes="(max-width: 720px) 100vw, 33vw"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    )
  }
</section>

<style>
  .local {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-800);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }
  .local h2 {
    margin: var(--space-2) 0 var(--space-4);
  }
  .local__context {
    color: var(--text-300);
    max-width: 70ch;
  }
  .local__media {
    display: grid;
    gap: var(--col-gap);
    margin-top: var(--space-8);
  }
  .local__media--1 {
    grid-template-columns: minmax(0, 520px);
  }
  .local__media--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .local__media--3 {
    grid-template-columns: 2fr 1fr 1fr;
  }
  .local__frame {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
  .local__frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 720px) {
    .local__media--2,
    .local__media--3 {
      grid-template-columns: 1fr;
    }
  }
</style>
