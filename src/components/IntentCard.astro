---
/**
 * Интент-карточка направления: строгая карточка с тонкой границей, кастомный мини-знак,
 * заголовок-интент, короткий подзаголовок. Hover — подсветка границы латунью + сдвиг
 * стрелки. Без иконок-клипарта.
 */
import Icon from './icons/Icon.astro';
import type { IconName } from './icons/paths';

interface Props {
  label: string;
  sub: string;
  href: string;
  icon: IconName;
  /** Двузначный индекс для моно-нумерации. */
  index: number;
}
const { label, sub, href, icon, index } = Astro.props;
---

<a href={href} class="intent-card perimeter">
  <span class="intent-card__top">
    <Icon name={icon} size={26} class="intent-card__icon" />
    <span class="intent-card__n mono">{String(index).padStart(2, '0')}</span>
  </span>
  <span class="intent-card__label">{label}</span>
  <span class="intent-card__sub">{sub}</span>
  <span class="intent-card__cta mono">
    Подробнее <Icon name="arrow" size={16} class="intent-card__arrow" />
  </span>
</a>

<style>
  .intent-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: var(--space-6) var(--space-5, 1.25rem) var(--space-5, 1.25rem);
    background: color-mix(in srgb, var(--bg-800) 86%, transparent);
    border: 1px solid var(--line);
    backdrop-filter: blur(4px);
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .intent-card:hover {
    border-color: var(--accent);
    background: var(--bg-700);
    transform: translateY(-2px);
  }
  .intent-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .intent-card__icon {
    color: var(--accent);
  }
  .intent-card__n {
    color: var(--text-500);
  }
  .intent-card__label {
    font-size: var(--fs-h3);
    font-weight: 500;
    color: var(--text-100);
    line-height: 1.2;
  }
  .intent-card__sub {
    font-size: var(--fs-small);
    color: var(--text-300);
    flex: 1;
  }
  .intent-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-500);
    text-transform: uppercase;
    transition: color var(--dur) var(--ease);
  }
  .intent-card:hover .intent-card__cta {
    color: var(--accent);
  }
  .intent-card__arrow {
    transition: transform var(--dur) var(--ease);
  }
  .intent-card:hover .intent-card__arrow {
    transform: translateX(3px);
  }
</style>
