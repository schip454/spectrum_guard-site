---
/**
 * Логотип Spectrum Guard: сигнатурный знак-визир + словесная марка.
 * Знак — угловые засечки вокруг точки (та же идея, что рамка-периметр).
 */
interface Props {
  /** Размер словесной марки. */
  compact?: boolean;
  href?: string | null;
}
const { compact = false, href = '/' } = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
  class:list={['logo', { 'logo--compact': compact }]}
  {...href ? { href, 'aria-label': 'Spectrum Guard — на главную' } : {}}
>
  <svg class="logo__mark" width="28" height="28" viewBox="0 0 28 28" aria-hidden="true">
    <path d="M2 8V2h6" fill="none" stroke="var(--accent)" stroke-width="1.5" />
    <path d="M26 8V2h-6" fill="none" stroke="var(--accent)" stroke-width="1.5" />
    <path d="M2 20v6h6" fill="none" stroke="var(--accent)" stroke-width="1.5" />
    <path d="M26 20v6h-6" fill="none" stroke="var(--accent)" stroke-width="1.5" />
    <circle cx="14" cy="14" r="2.2" fill="var(--accent)" />
    <circle cx="14" cy="14" r="6" fill="none" stroke="var(--line-2)" stroke-width="1" />
  </svg>
  <span class="logo__word">
    <span class="logo__name">Spectrum&nbsp;Guard</span>
    {!compact && <span class="logo__tag mono">безопасность · 8 городов</span>}
  </span>
</Tag>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-100);
  }
  .logo__mark {
    flex-shrink: 0;
  }
  .logo__word {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo__name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.01em;
  }
  .logo__tag {
    margin-top: 2px;
    font-size: 0.6875rem;
    color: var(--text-500);
  }
  .logo--compact .logo__name {
    font-size: 1rem;
  }
</style>
