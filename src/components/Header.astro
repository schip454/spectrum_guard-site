---
/**
 * Шапка: логотип, навигация, телефон и CTA. Мобильное меню — на нативном
 * <details> + минимальном JS-улучшении (закрытие по Esc/клику по ссылке).
 */
import Logo from './Logo.astro';
import Icon from './icons/Icon.astro';
import Button from './Button.astro';
import { mainNav } from '../data/nav';
import { contacts } from '../data/contacts';
import { SHOW_PHONE } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href !== '/' && currentPath.startsWith(href.replace(/[^/]+\/$/, '')) && href.length > 1
    ? currentPath.startsWith(href)
    : currentPath === href;
---

<header class="site-header">
  <div class="container site-header__inner">
    <Logo />

    <nav class="nav" aria-label="Основная навигация">
      <ul class="nav__list">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav__link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      {
        SHOW_PHONE ? (
          <details class="phones-dd">
            <summary class="phones-dd__toggle" aria-label="Показать телефоны">
              <Icon name="phone" size={16} />
              <span>Телефоны</span>
              <span class="phones-dd__chev" aria-hidden="true" />
            </summary>
            <div class="phones-dd__panel">
              <p class="phones-dd__label mono">Звонок за консультацией</p>
              {contacts.phones.map((p) => (
                <a href={`tel:${p.tel}`} class="phones-dd__num">
                  <Icon name="phone" size={16} /> {p.display}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a href={contacts.telegram.url} class="site-header__phone mono" rel="noopener" target="_blank" aria-label="Написать в Telegram">
            <Icon name="telegram" size={16} />
            <span>Telegram</span>
          </a>
        )
      }
      <Button href="#lead" variant="primary" size="md">Оставить заявку</Button>
    </div>

    <details class="mobile-menu">
      <summary class="mobile-menu__toggle" aria-label="Открыть меню">
        <Icon name="menu" size={24} class="mobile-menu__open" />
        <Icon name="close" size={24} class="mobile-menu__close" />
      </summary>
      <div class="mobile-menu__panel">
        <ul class="mobile-menu__list">
          {
            mainNav.map((item) => (
              <li>
                <a href={item.href} class:list={['mobile-menu__link', { 'is-active': isActive(item.href) }]}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        {
          SHOW_PHONE &&
            contacts.phones.map((p) => (
              <a href={`tel:${p.tel}`} class="mobile-menu__phone">
                <Icon name="phone" size={18} />
                {p.display}
              </a>
            ))
        }
        <a href={contacts.telegram.url} class="mobile-menu__phone" rel="noopener" target="_blank">
          <Icon name="telegram" size={18} />
          Написать в Telegram
        </a>
        <Button href="#lead" variant="primary" size="lg" full>Оставить заявку</Button>
      </div>
    </details>
  </div>
</header>

<script>
  // Лёгкое улучшение: закрыть мобильное меню по Esc и по клику на ссылку.
  const menu = document.querySelector<HTMLDetailsElement>('.mobile-menu');
  if (menu) {
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => menu.removeAttribute('open'))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') menu.removeAttribute('open');
    });
  }

  // Дропдаун телефонов: закрытие по Esc, клику вне и по выбору номера.
  const phonesDd = document.querySelector<HTMLDetailsElement>('.phones-dd');
  if (phonesDd) {
    phonesDd.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => phonesDd.removeAttribute('open'))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') phonesDd.removeAttribute('open');
    });
    document.addEventListener('click', (e) => {
      if (phonesDd.open && !phonesDd.contains(e.target as Node)) phonesDd.removeAttribute('open');
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--bg-900) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-height: 68px;
  }

  .nav {
    margin-inline-start: auto;
  }
  .nav__list {
    display: flex;
    gap: clamp(0.75rem, 1.6vw, 1.5rem);
  }
  .nav__link {
    font-size: var(--fs-small);
    color: var(--text-300);
    padding-block: 0.5rem;
    border-bottom: 1px solid transparent;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .nav__link:hover {
    color: var(--text-100);
  }
  .nav__link.is-active {
    color: var(--text-100);
    border-bottom-color: var(--accent);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .site-header__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-100);
    font-size: var(--fs-small);
  }
  .site-header__phone:hover {
    color: var(--accent);
  }

  /* ---------- Дропдаун телефонов ---------- */
  .phones-dd {
    position: relative;
  }
  .phones-dd__toggle {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    color: var(--text-100);
    font-size: var(--fs-small);
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .phones-dd__toggle::-webkit-details-marker {
    display: none;
  }
  .phones-dd__toggle:hover {
    border-color: var(--accent);
  }
  .phones-dd__chev {
    width: 7px;
    height: 7px;
    border-right: 1.5px solid var(--text-300);
    border-bottom: 1.5px solid var(--text-300);
    transform: rotate(45deg) translate(-1px, -1px);
    transition: transform var(--dur) var(--ease);
  }
  .phones-dd[open] .phones-dd__chev {
    transform: rotate(-135deg) translate(-1px, -1px);
  }
  .phones-dd__panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    z-index: var(--z-overlay);
    min-width: 230px;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--bg-700);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
  }
  .phones-dd__label {
    color: var(--text-500);
    margin-bottom: var(--space-2);
  }
  .phones-dd__num {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    color: var(--text-100);
    font-weight: 500;
    transition: background-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .phones-dd__num :global(svg) {
    color: var(--accent);
  }
  .phones-dd__num:hover {
    background: var(--bg-800);
    color: var(--accent);
  }

  /* ---------- Мобильное меню ---------- */
  .mobile-menu {
    display: none;
    margin-inline-start: auto;
  }
  .mobile-menu__toggle {
    list-style: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--text-100);
    cursor: pointer;
  }
  .mobile-menu__toggle::-webkit-details-marker {
    display: none;
  }
  .mobile-menu__close {
    display: none;
  }
  .mobile-menu[open] .mobile-menu__open {
    display: none;
  }
  .mobile-menu[open] .mobile-menu__close {
    display: block;
  }
  .mobile-menu__panel {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    background: var(--bg-800);
    border-bottom: 1px solid var(--line);
    padding: var(--space-6) var(--gutter) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mobile-menu__list {
    display: flex;
    flex-direction: column;
  }
  .mobile-menu__link {
    display: block;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--line);
    color: var(--text-100);
    font-size: var(--fs-body);
  }
  .mobile-menu__link.is-active {
    color: var(--accent);
  }
  .mobile-menu__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding-block: var(--space-2);
    color: var(--text-100);
  }

  @media (max-width: 940px) {
    .nav,
    .site-header__actions {
      display: none;
    }
    .mobile-menu {
      display: block;
    }
  }
</style>
