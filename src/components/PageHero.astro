---
/**
 * Внутренний заголовок страницы. H1 + Answer-First врезка, сигнатурные засечки.
 * Необязательный фоновый кадр (через astro:assets) под затемнением — для услуговых,
 * гео- и блоговых страниц. Без кадра — глубина через слои и хайрлайны.
 */
import AnswerFirst from './AnswerFirst.astro';
import Media from './Media.astro';

interface Props {
  eyebrow?: string;
  h1: string;
  answer?: string;
  /** Моно-метка над врезкой (код города/услуга). */
  answerLabel?: string;
  /** Ключ фонового изображения (реестр lib/media). */
  image?: string;
  imageAlt?: string;
}
const { eyebrow, h1, answer, answerLabel, image, imageAlt } = Astro.props;
const hasImage = !!image;
---

<header class:list={['page-hero', { 'page-hero--media': hasImage }]}>
  {
    hasImage && (
      <div class="page-hero__bg" aria-hidden="true">
        <Media
          src={image!}
          alt={imageAlt ?? h1}
          sizes="100vw"
          widths={[768, 1080, 1280]}
          loading="eager"
          fetchpriority="high"
          class="page-hero__img"
        />
        <div class="page-hero__scrim"></div>
      </div>
    )
  }
  <div class="container page-hero__inner">
    <div class="page-hero__frame perimeter">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{h1}</h1>
      {answer && <AnswerFirst text={answer} label={answerLabel} />}
    </div>
  </div>
</header>

<style>
  .page-hero {
    position: relative;
    padding-block: var(--space-16) var(--space-12);
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(195, 154, 85, 0.05), transparent 60%),
      var(--bg-900);
  }
  .page-hero--media {
    padding-block: var(--space-24) var(--space-12);
    overflow: hidden;
  }
  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .page-hero__bg :global(.page-hero__img),
  .page-hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .page-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(11, 13, 16, 0.62) 0%,
      rgba(11, 13, 16, 0.82) 65%,
      var(--bg-900) 100%
    );
  }
  .page-hero__inner {
    position: relative;
    z-index: 1;
  }
  .page-hero__frame {
    padding-top: var(--space-2);
    padding-left: var(--space-4);
  }
  .page-hero--media .page-hero__frame {
    background: color-mix(in srgb, var(--bg-900) 30%, transparent);
    backdrop-filter: blur(2px);
    padding: var(--space-6) var(--space-6) var(--space-4);
    border-radius: var(--radius);
  }
  .page-hero h1 {
    max-width: 22ch;
    margin: var(--space-3) 0 var(--space-6);
  }
  .page-hero .eyebrow {
    color: var(--accent);
  }
</style>
