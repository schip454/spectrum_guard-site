---
/**
 * Единый компонент аналитики. Подключается только если в config заданы ID.
 * До запуска — выключено (никаких сторонних аналитик, кроме Метрики и GA).
 */
import { ANALYTICS } from '../config';
const { yandexMetrikaId, googleAnalyticsId } = ANALYTICS;
---

{
  yandexMetrikaId && (
    <Fragment>
      <script is:inline define:vars={{ id: yandexMetrikaId }}>
        (function (m, e, t, r, i, k, a) {
          m[i] =
            m[i] ||
            function () {
              (m[i].a = m[i].a || []).push(arguments);
            };
          m[i].l = 1 * new Date();
          (k = e.createElement(t)), (a = e.getElementsByTagName(t)[0]), (k.async = 1), (k.src = r), a.parentNode.insertBefore(k, a);
        })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');
        ym(id, 'init', { clickmap: true, trackLinks: true, accurateTrackBounce: true });
      </script>
      <noscript>
        <div>
          <img src={`https://mc.yandex.ru/watch/${yandexMetrikaId}`} style="position:absolute;left:-9999px" alt="" />
        </div>
      </noscript>
    </Fragment>
  )
}

{
  googleAnalyticsId && (
    <Fragment>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`} />
      <script is:inline define:vars={{ id: googleAnalyticsId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());
        gtag('config', id);
      </script>
    </Fragment>
  )
}
