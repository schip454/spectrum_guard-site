---
/**
 * Хлебные крошки. Schema BreadcrumbList отдаётся на странице через lib/schema,
 * здесь — только видимая навигация (одна сущность, без дублей).
 */
interface Crumb {
  name: string;
  href: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
  <ol class="container">
    {
      crumbs.map((c, i) => (
        <li class="breadcrumbs__item">
          {i < crumbs.length - 1 ? (
            <a href={c.href}>{c.name}</a>
          ) : (
            <span aria-current="page">{c.name}</span>
          )}
          {i < crumbs.length - 1 && <span class="breadcrumbs__sep" aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    border-bottom: 1px solid var(--line);
    background: var(--bg-900);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    padding-block: var(--space-4);
  }
  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .breadcrumbs a {
    color: var(--text-500);
  }
  .breadcrumbs a:hover {
    color: var(--text-100);
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--text-300);
  }
  .breadcrumbs__sep {
    color: var(--text-500);
    opacity: 0.5;
  }
</style>
