---
/**
 * Баннер согласия на cookie/аналитику. Аналитика (Яндекс Метрика и пр.) подключается
 * только после «Принять». Выбор хранится в localStorage. Прячется без JS-мерцания
 * (скрыт по умолчанию, показывается скриптом, если выбор ещё не сделан).
 */
---

<div class="cookie" data-cookie hidden>
  <p class="cookie__text">
    Мы используем cookie и веб-аналитику, чтобы сайт работал лучше. Подробнее — в
    <a href="/politika-konfidencialnosti/">политике конфиденциальности</a>.
  </p>
  <div class="cookie__actions">
    <button type="button" class="cookie__btn cookie__btn--ghost" data-cookie-reject>Только необходимые</button>
    <button type="button" class="cookie__btn cookie__btn--primary" data-cookie-accept>Принять</button>
  </div>
</div>

<script>
  const KEY = 'sg-cookie-consent';
  const banner = document.querySelector<HTMLElement>('[data-cookie]');
  if (banner) {
    const choice = localStorage.getItem(KEY);
    if (choice === 'granted') {
      window.sgLoadAnalytics?.();
    } else if (!choice) {
      banner.hidden = false;
      requestAnimationFrame(() => banner.classList.add('is-in'));
    }
    const close = () => {
      banner.classList.remove('is-in');
      window.setTimeout(() => (banner.hidden = true), 250);
    };
    banner.querySelector('[data-cookie-accept]')?.addEventListener('click', () => {
      localStorage.setItem(KEY, 'granted');
      window.sgLoadAnalytics?.();
      close();
    });
    banner.querySelector('[data-cookie-reject]')?.addEventListener('click', () => {
      localStorage.setItem(KEY, 'denied');
      close();
    });
  }
</script>

<style>
  .cookie[hidden] {
    display: none;
  }
  .cookie {
    position: fixed;
    left: var(--space-4);
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: var(--z-toast);
    margin-inline: auto;
    max-width: 720px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5, 1.25rem) var(--space-6);
    background: var(--bg-700);
    border: 1px solid var(--line-2);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .cookie.is-in {
    opacity: 1;
    transform: none;
  }
  .cookie__text {
    flex: 1;
    min-width: 220px;
    font-size: var(--fs-small);
    color: var(--text-300);
  }
  .cookie__text a {
    color: var(--accent);
    text-decoration: underline;
  }
  .cookie__actions {
    display: flex;
    gap: var(--space-3);
  }
  .cookie__btn {
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius);
    border: 1px solid transparent;
    font-size: var(--fs-small);
    font-weight: 500;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .cookie__btn--ghost {
    border-color: var(--line-2);
    color: var(--text-300);
  }
  .cookie__btn--ghost:hover {
    border-color: var(--text-300);
    color: var(--text-100);
  }
  .cookie__btn--primary {
    background: var(--accent);
    color: #1a1206;
    font-weight: 700;
  }
  .cookie__btn--primary:hover {
    background: #d4ab63;
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie {
      transition: none;
    }
  }
</style>
