---
/**
 * Изображение через astro:assets (Picture → avif/webp, заданные размеры = нулевой CLS).
 * Грейд уже запечён в мастер. По умолчанию object-fit: cover в контейнере вызывающего.
 * Если ключ не найден — рендерим аккуратный плейсхолдер (без битой картинки).
 */
import { Image } from 'astro:assets';
import { getMedia } from '../lib/media';

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  widths?: number[];
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  sizes = '(max-width: 720px) 100vw, 50vw',
  widths = [480, 960, 1280],
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;

const img = getMedia(src);
---

{
  img ? (
    <Image
      src={img}
      format="webp"
      quality={70}
      alt={alt}
      sizes={sizes}
      widths={widths.filter((w) => w <= (img.width ?? 1280))}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding="async"
      class:list={['media', className]}
    />
  ) : (
    <div class:list={['media media--placeholder', className]} role="img" aria-label={alt} />
  )
}

<style>
  .media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .media--placeholder {
    background:
      radial-gradient(120% 120% at 30% 0%, rgba(195, 154, 85, 0.07), transparent 60%),
      var(--bg-700);
  }
</style>
