---
/**
 * Главная `/`. Hero → один сильный блок услуг (карточки с фото) → о компании →
 * преимущества → география (9 городов) → конверсия. Без дублирующих блоков услуг
 * (см. правки → пункты 2, 4). Schema: Organization (сайтово). Без хлебных крошек.
 */
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CityCard from '../components/CityCard.astro';
import AnswerFirst from '../components/AnswerFirst.astro';
import CtaSection from '../components/CtaSection.astro';
import Reviews from '../components/Reviews.astro';
import Media from '../components/Media.astro';
import Icon from '../components/icons/Icon.astro';
import type { IconName } from '../components/icons/paths';
import { services } from '../data/services';
import { cities } from '../data/cities';

const title = 'Spectrum Guard — охрана и личная безопасность в 9 городах России';
const description =
  'Spectrum Guard — охранное агентство: личная охрана, защита при угрозах, охрана при ' +
  'переезде, помощь при конфликте с соседями и охрана мероприятий. Работаем в Москве, ' +
  'Санкт-Петербурге, Екатеринбурге, Новосибирске, Сочи, Уфе, Челябинске, Перми и Тюмени. ' +
  'Оставьте заявку или напишите в Telegram.';

const why = [
  {
    icon: 'guard' as const,
    title: 'Действуем по закону',
    text: 'Обеспечиваем безопасность и фиксируем факты, но не давим на третьих лиц. Защита, а не самосуд.',
  },
  {
    icon: 'threat' as const,
    title: 'Без лишнего внимания',
    text: 'Детали задачи и данные клиента не разглашаем. Работаем спокойно и не привлекаем внимания.',
  },
  {
    icon: 'pin' as const,
    title: '9 городов России',
    text: 'Москва, Санкт-Петербург, Екатеринбург, Новосибирск, Сочи, Уфа, Челябинск, Пермь, Тюмень.',
  },
  {
    icon: 'clock' as const,
    title: 'Заявки 24/7',
    text: 'Перезвоним или ответим в Telegram. Подберём формат под задачу — от разовой смены до постоянного режима.',
  },
];
---

<Base {title} {description} path="/">
  <Hero />

  {/* Один сильный блок услуг — карточки с реальными кадрами */}
  <section class="section container" aria-labelledby="services-heading">
    <p class="eyebrow">Что мы делаем</p>
    <h2 id="services-heading" class="home-h2">Шесть направлений</h2>
    <ul class="services-grid">
      {
        services.map((s, i) => (
          <li>
            <ServiceCard
              label={s.intentLabel}
              sub={s.tagline}
              href={`/uslugi/${s.slug}/`}
              icon={s.icon as IconName}
              image={s.cardImage}
              index={i + 1}
            />
          </li>
        ))
      }
    </ul>
  </section>

  {/* Отзывы — реальные обезличенные скриншоты */}
  <section class="section container">
    <Reviews heading="Отзывы клиентов" />
  </section>

  {/* О компании — с кадром */}
  <section class="section container" aria-labelledby="about-heading">
    <div class="about-home">
      <div class="about-home__text">
        <p class="eyebrow">О компании</p>
        <h2 id="about-heading" class="home-h2">Охрана под конкретную задачу</h2>
        <AnswerFirst
          text="Spectrum Guard — охранное агентство для частных клиентов и бизнеса. Помогаем там, где нужна безопасность человека: личная охрана и сопровождение, защита при угрозах, спокойный переезд, помощь с соседями, охрана мероприятий и перевозка ценных грузов. Работаем в девяти городах России, а по запросу выезжаем по всей стране."
        />
        <p class="about-home__more">
          Подбираем формат под ситуацию — от разовой смены до постоянного режима. Сначала
          короткий разговор: что происходит, какие риски, что нужно. Затем согласуем план,
          состав и стоимость — без скрытых доплат.
        </p>
        <a href="/o-kompanii/" class="about-home__link mono">
          Подробнее о компании <Icon name="arrow" size={16} />
        </a>
      </div>
      <figure class="about-home__media reveal">
        <Media
          src="neutral/neutral-penthouse-interior-01.webp"
          alt="Spectrum Guard — сопровождение и личная безопасность"
          sizes="(max-width: 900px) 100vw, 45vw"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  {/* Преимущества */}
  <section class="section container" aria-labelledby="why-heading">
    <p class="eyebrow">Почему Spectrum Guard</p>
    <h2 id="why-heading" class="home-h2">Профессионально и дискретно</h2>
    <ul class="why">
      {
        why.map((w) => (
          <li class="why__item perimeter reveal">
            <span class="why__icon" aria-hidden="true"><Icon name={w.icon} size={24} /></span>
            <div class="why__body">
              <h3 class="why__title">{w.title}</h3>
              <p class="why__text">{w.text}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  {/* География — 9 городов с кадрами, выбор города */}
  <section class="section container" aria-labelledby="geo-heading">
    <div class="geo-head">
      <div>
        <p class="eyebrow">География</p>
        <h2 id="geo-heading" class="home-h2">9 городов России</h2>
        <p class="geo-note">Остальные города — по запросу. Выезжаем в любые уголки страны.</p>
      </div>
      <a href="/goroda/" class="geo-head__all mono">Все города <Icon name="arrow" size={16} /></a>
    </div>
    <ul class="geo-grid">
      {
        cities.map((c) => (
          <li><CityCard city={c} /></li>
        ))
      }
    </ul>
  </section>

  <CtaSection source="Главная страница" />
</Base>

<style>
  .home-h2 {
    max-width: 24ch;
    margin: var(--space-2) 0 var(--space-6);
  }

  /* 6 направлений — ровная сетка 3×2, картинки и текст с воздухом. */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--col-gap);
  }
  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-home {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about-home__more {
    color: var(--text-300);
    max-width: 60ch;
    margin-top: var(--space-6);
  }
  .about-home__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    color: var(--accent);
  }
  .about-home__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
  .about-home__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 900px) {
    .about-home {
      grid-template-columns: 1fr;
    }
    .about-home__media {
      order: -1;
    }
  }

  .why {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--col-gap);
    margin-top: var(--space-6);
  }
  .why__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--line);
    background: var(--bg-800);
  }
  .why__icon {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--accent);
    padding: var(--space-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
  }
  .why__title {
    margin-bottom: var(--space-2);
  }
  .why__text {
    color: var(--text-300);
    font-size: var(--fs-small);
  }
  @media (max-width: 900px) {
    .why {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .why {
      grid-template-columns: 1fr;
    }
  }

  .geo-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .geo-head .home-h2 {
    margin-bottom: var(--space-2);
  }
  .geo-note {
    color: var(--text-300);
    font-size: var(--fs-small);
    max-width: 40ch;
  }
  .geo-head__all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--accent);
    white-space: nowrap;
    padding-bottom: var(--space-2);
  }
  .geo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--col-gap);
  }
  @media (max-width: 1000px) {
    .geo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .geo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
