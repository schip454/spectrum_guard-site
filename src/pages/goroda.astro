---
/**
 * `/goroda/` — полноценный список городов присутствия с выбором (см. правки → пункт 6:
 * «География» больше не ведёт сразу в Москву). Города с локальной фактурой — первыми.
 */
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import CityCard from '../components/CityCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { cities } from '../data/cities';
import { breadcrumbSchema } from '../lib/schema';

const title = 'Города присутствия — Spectrum Guard';
const description =
  'Spectrum Guard работает в 8 городах России: Москва, Санкт-Петербург, Екатеринбург, ' +
  'Новосибирск, Уфа, Челябинск, Пермь, Тюмень. Выберите свой город — личная охрана, защита ' +
  'при угрозах, охрана мероприятий и другие услуги.';
const path = '/goroda/';

const crumbs = [
  { name: 'Главная', href: '/' },
  { name: 'Города', href: path },
];

const withProof = cities.filter((c) => c.hasLocalProof);
const outreach = cities.filter((c) => !c.hasLocalProof);
---

<Base {title} {description} {path} schemas={[breadcrumbSchema(crumbs)]}>
  <Breadcrumbs {crumbs} />

  <PageHero
    eyebrow="География"
    h1="Города присутствия"
    answer="Spectrum Guard работает в восьми городах России. Выберите свой город — увидите доступные услуги, локальный контекст и сможете оставить заявку. Работаем выездным форматом по согласованному маршруту, в правовом поле и конфиденциально."
  />

  <section class="container section">
    <p class="eyebrow goroda__eyebrow">Опорные города</p>
    <h2 class="goroda__h2">Есть местная фактура</h2>
    <ul class="goroda__grid">
      {withProof.map((c) => (
        <li><CityCard city={c} /></li>
      ))}
    </ul>

    <p class="eyebrow goroda__eyebrow goroda__eyebrow--mt">Выездной формат</p>
    <h2 class="goroda__h2">Работаем по согласованному маршруту</h2>
    <ul class="goroda__grid">
      {outreach.map((c) => (
        <li><CityCard city={c} /></li>
      ))}
    </ul>
  </section>

  <CtaSection source="Страница городов" />
</Base>

<style>
  .goroda__eyebrow {
    color: var(--accent);
  }
  .goroda__eyebrow--mt {
    margin-top: var(--space-16);
  }
  .goroda__h2 {
    margin: var(--space-2) 0 var(--space-6);
  }
  .goroda__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--col-gap);
  }
  @media (max-width: 1000px) {
    .goroda__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .goroda__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
