---
/**
 * `/goroda/` — список городов с выбором (см. правки → пункт 6: «География» не ведёт
 * сразу в Москву). Все города показываем единообразно, без деления на «опорные/выездные».
 */
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import CityCard from '../components/CityCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { cities } from '../data/cities';
import { breadcrumbSchema } from '../lib/schema';

const title = 'Города присутствия — Spectrum Guard';
const description =
  'Spectrum Guard — собственная команда в 9 ключевых городах: Москва, Санкт-Петербург, ' +
  'Екатеринбург, Новосибирск, Сочи, Уфа, Челябинск, Пермь, Тюмень. По запросу выезжаем в любой ' +
  'регион России. Выберите свой город — личная охрана, защита при угрозах, мероприятия и другое.';
const path = '/goroda/';

const crumbs = [
  { name: 'Главная', href: '/' },
  { name: 'Города', href: path },
];
---

<Base {title} {description} {path} schemas={[breadcrumbSchema(crumbs)]}>
  <Breadcrumbs {crumbs} />

  <PageHero
    eyebrow="География"
    h1="Города присутствия"
    answer="Spectrum Guard работает в девяти городах России, а остальные города берём по запросу — выезжаем в любые уголки страны. Выберите свой город или просто оставьте заявку: её возьмёт в работу команда на месте и согласует формат, время и стоимость."
  />

  <section class="container section">
    <ul class="goroda__grid">
      {cities.map((c) => (
        <li class="reveal"><CityCard city={c} /></li>
      ))}
    </ul>
  </section>

  <CtaSection source="Страница городов" />
</Base>

<style>
  .goroda__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--col-gap);
  }
  @media (max-width: 1000px) {
    .goroda__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .goroda__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
