---
/**
 * `/otzyvy/` — реальные обезличенные отзывы (скриншоты). Если отзывов нет (флаг выключен) —
 * честное приглашение оставить обратную связь. AggregateRating не выдумываем.
 */
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import Reviews from '../components/Reviews.astro';
import CtaSection from '../components/CtaSection.astro';
import { reviewShots } from '../data/reviews';
import { REVIEWS_ENABLED } from '../config';
import { breadcrumbSchema } from '../lib/schema';

const title = 'Отзывы — Spectrum Guard';
const description =
  'Отзывы клиентов Spectrum Guard — реальный обезличенный опыт работы. Оставьте заявку или ' +
  'напишите в Telegram — поможем с личной безопасностью.';
const path = '/otzyvy/';

const crumbs = [
  { name: 'Главная', href: '/' },
  { name: 'Отзывы', href: path },
];

const showReviews = REVIEWS_ENABLED && reviewShots.length > 0;
---

<Base {title} {description} {path} schemas={[breadcrumbSchema(crumbs)]}>
  <Breadcrumbs {crumbs} />

  <PageHero
    eyebrow="Отзывы"
    h1="Что говорят клиенты"
    answer="Здесь — реальные отзывы о работе Spectrum Guard. Мы публикуем их обезличенно: имена и аватары скрыты для конфиденциальности. Хотите поделиться опытом или задать вопрос — напишите нам в Telegram или оставьте заявку."
  />

  <section class="container section">
    {
      showReviews ? (
        <Reviews heading="Отзывы клиентов" eyebrow="Реальный опыт, обезличенно" />
      ) : (
        <div class="reviews-empty perimeter">
          <p class="reviews-empty__lead">
            Мы собираем отзывы клиентов и публикуем их по согласию. Если вы уже работали с нами —
            будем благодарны за обратную связь в Telegram.
          </p>
          <p class="reviews-empty__sub">
            А если только выбираете — оставьте заявку, ответим на вопросы и расскажем, как работаем.
          </p>
        </div>
      )
    }
  </section>

  <CtaSection source="Страница отзывов" heading="Остались вопросы?" />
</Base>

<style>
  .reviews-empty {
    max-width: 64ch;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--line);
    border-left: 2px solid var(--accent);
    background: var(--bg-800);
  }
  .reviews-empty__lead {
    color: var(--text-100);
    font-size: var(--fs-h3);
    line-height: 1.5;
  }
  .reviews-empty__sub {
    color: var(--text-300);
    margin-top: var(--space-4);
  }
</style>
