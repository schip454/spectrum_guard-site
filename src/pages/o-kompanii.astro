---
/**
 * `/o-kompanii/` — о Spectrum Guard, принципы, география. Слот трастового блока (за
 * флагом). Без выдуманных фактов и без упоминания, что лицензия «будет позже».
 */
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import LinkCardGrid from '../components/LinkCardGrid.astro';
import type { LinkCardItem } from '../components/LinkCardGrid.astro';
import TrustBlock from '../components/TrustBlock.astro';
import CtaSection from '../components/CtaSection.astro';
import Media from '../components/Media.astro';
import Icon from '../components/icons/Icon.astro';
import { services } from '../data/services';
import { cities } from '../data/cities';
import { breadcrumbSchema } from '../lib/schema';

const title = 'О компании — Spectrum Guard';
const description =
  'Spectrum Guard — охранное агентство для частных клиентов и бизнеса. Как мы работаем, ' +
  'принципы и чем помогаем. Личная охрана, защита при угрозах, переезд, соседи, мероприятия в 9 городах.';
const path = '/o-kompanii/';

const crumbs = [
  { name: 'Главная', href: '/' },
  { name: 'О компании', href: path },
];

const serviceLinks: LinkCardItem[] = services.map((s) => ({
  title: s.nameNom,
  sub: s.tagline,
  href: `/uslugi/${s.slug}/`,
  icon: s.icon as LinkCardItem['icon'],
}));

const principles = [
  {
    icon: 'guard' as const,
    title: 'Закон выше эмоций',
    text:
      'Обеспечиваем безопасность и действуем в рамках закона. Не давим на третьих лиц и не ' +
      'участвуем в самосуде — наша задача защитить вас, а не свести счёты.',
  },
  {
    icon: 'threat' as const,
    title: 'Конфиденциальность',
    text: 'Детали задачи и данные клиента не разглашаем. Работаем спокойно, без лишнего внимания.',
  },
  {
    icon: 'check' as const,
    title: 'Честность об ограничениях',
    text:
      'Берём задачу, когда уверены, что поможем. Если что-то вне нашей компетенции — говорим прямо ' +
      'и подсказываем, куда обратиться.',
  },
];
---

<Base {title} {description} {path} schemas={[breadcrumbSchema(crumbs)]}>
  <Breadcrumbs {crumbs} />

  <PageHero
    eyebrow="О компании"
    h1="Spectrum Guard"
    answer="Spectrum Guard — охранное агентство для частных клиентов и бизнеса. Помогаем там, где нужна безопасность человека: личная охрана, защита при угрозах, спокойный переезд, помощь с соседями, охрана мероприятий и сопровождение сделок с перевозкой денег. Работаем в девяти городах России, а по запросу выезжаем по всей стране — заявку ведёт команда на месте."
    image="hero/msk-kotelnicheskaya-sunset-hero.webp"
    imageAlt="Spectrum Guard — охранное агентство"
  />

  <section class="container section about">
    <div class="about__prose">
      <h2>Как мы работаем</h2>
      <ol class="about__steps">
        <li>
          <span class="about__step-n mono">01</span>
          <div>
            <h3>Вы оставляете заявку</h3>
            <p>На сайте, в Telegram или звонком. Достаточно коротко описать ситуацию и город.</p>
          </div>
        </li>
        <li>
          <span class="about__step-n mono">02</span>
          <div>
            <h3>Мы связываемся и обсуждаем задачу</h3>
            <p>Уточняем, что происходит, какой формат нужен и в какие сроки.</p>
          </div>
        </li>
        <li>
          <span class="about__step-n mono">03</span>
          <div>
            <h3>Передаём заявку команде в вашем городе</h3>
            <p>Задачей занимаются люди на месте — те, кто будет работать с вами.</p>
          </div>
        </li>
        <li>
          <span class="about__step-n mono">04</span>
          <div>
            <h3>Команда согласует время и стоимость</h3>
            <p>На месте оценивают задачу, называют цену без скрытых доплат и берут её в работу.</p>
          </div>
        </li>
      </ol>
    </div>

    <div class="about-strip">
      <figure class="about-strip__frame reveal">
        <Media src="neutral/neutral-convoy-highway-03.webp" alt="Сопровождение и кортеж — Spectrum Guard" sizes="(max-width: 760px) 100vw, 50vw" loading="lazy" />
      </figure>
      <figure class="about-strip__frame reveal">
        <Media src="moskva/msk-city-rangerover-01.webp" alt="Личная охрана и сопровождение в городе" sizes="(max-width: 760px) 100vw, 50vw" loading="lazy" />
      </figure>
    </div>

    <ul class="principles">
      {
        principles.map((p) => (
          <li class="principles__item perimeter">
            <span class="principles__icon" aria-hidden="true"><Icon name={p.icon} size={24} /></span>
            <div class="principles__body">
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="about__geo">
      <h2>География</h2>
      <p class="about__geo-text">
        Работаем в {cities.length} городах России: {cities.map((c) => c.nom).join(', ')}.
        В каждом городе задачу ведут люди на месте.
      </p>
    </div>

    <TrustBlock />
  </section>

  <section class="container section">
    <LinkCardGrid eyebrow="Направления" heading="Чем помогаем" items={serviceLinks} columns={3} />
  </section>

  <CtaSection source="О компании" />
</Base>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .about__prose {
    max-width: 70ch;
  }
  .about__steps {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6) var(--space-8);
    margin-top: var(--space-6);
  }
  .about__steps li {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  .about__step-n {
    color: var(--accent);
    padding-top: 0.2rem;
    flex-shrink: 0;
  }
  .about__steps h3 {
    margin-bottom: var(--space-2);
  }
  .about__steps p {
    color: var(--text-300);
    font-size: var(--fs-small);
  }
  @media (max-width: 640px) {
    .about__steps {
      grid-template-columns: 1fr;
    }
  }
  .about__prose h2 {
    margin-bottom: var(--space-4);
  }
  .about__prose p {
    color: var(--text-300);
  }
  .about-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--col-gap);
  }
  .about-strip__frame {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
  .about-strip__frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 760px) {
    .about-strip {
      grid-template-columns: 1fr;
    }
  }
  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--col-gap);
  }
  .principles__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--line);
    background: var(--bg-800);
  }
  .principles__icon {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--accent);
    padding: var(--space-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
  }
  .principles__item h3 {
    margin-bottom: var(--space-2);
  }
  .principles__item p {
    color: var(--text-300);
    font-size: var(--fs-small);
  }
  .about__geo h2 {
    margin-bottom: var(--space-3);
  }
  .about__geo-text {
    max-width: 70ch;
    color: var(--text-300);
  }
  @media (max-width: 760px) {
    .principles {
      grid-template-columns: 1fr;
    }
  }
</style>
