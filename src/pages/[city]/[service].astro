---
/**
 * Гео-страница «услуга × город». Генерирует 40 страниц через getStaticPaths()
 * (декартово произведение cities × services). Никакого копипаста.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CityServiceTemplate from '../../components/CityServiceTemplate.astro';
import type { LinkCardItem } from '../../components/LinkCardGrid.astro';
import { cities } from '../../data/cities';
import { services } from '../../data/services';
import { geoTitle, geoDescription, geoH1, geoAnswerFirst } from '../../lib/content';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';
import type { City, Service } from '../../data/types';

export function getStaticPaths() {
  return cities.flatMap((city) =>
    services.map((service) => ({
      params: { city: city.slug, service: service.slug },
      props: { city, service },
    }))
  );
}

interface Props {
  city: City;
  service: Service;
}
const { city, service } = Astro.props as Props;

const path = `/${city.slug}/${service.slug}/`;
const title = geoTitle(service, city);
const description = geoDescription(service, city);

const crumbs = [
  { name: 'Главная', href: '/' },
  { name: city.nom, href: `/${city.slug}/` },
  { name: service.nameNom, href: path },
];

// Релевантные статьи блога по профильной услуге (1–2).
const relatedArticles: LinkCardItem[] = (
  await getCollection('blog', ({ data }) => !data.draft && data.relatedService === service.slug)
)
  .slice(0, 2)
  .map((post) => ({ title: post.data.title, sub: 'Статья', href: `/blog/${post.id}/` }));

const schemas = [
  serviceSchema({
    service,
    city,
    url: path,
    name: geoH1(service, city),
    description: geoAnswerFirst(service, city),
  }),
  faqSchema(service.faq),
  breadcrumbSchema(crumbs),
];
---

<Base {title} {description} {path} {schemas}>
  <Breadcrumbs {crumbs} />
  <CityServiceTemplate {city} {service} {relatedArticles} />
</Base>
